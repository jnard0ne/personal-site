---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal website" } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="text-stone-900 min-h-screen">
    <header class="border-b border-cream-200">
      <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-semibold text-lg hover:text-stone-600 transition-colors">
          John Nardone
        </a>
        <ul class="flex gap-6 text-sm">
          <li>
            <a
              href="/"
              class={`hover:text-stone-700 transition-colors ${isActive("/") ? "font-medium text-stone-900" : "text-stone-500"}`}
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/projects"
              class={`hover:text-stone-700 transition-colors ${isActive("/projects") ? "font-medium text-stone-900" : "text-stone-500"}`}
            >
              Projects
            </a>
          </li>
          <li>
            <a
              href="/blog"
              class={`hover:text-stone-700 transition-colors ${isActive("/blog") ? "font-medium text-stone-900" : "text-stone-500"}`}
            >
              Blog
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-cream-200 mt-16">
      <div class="max-w-3xl mx-auto px-6 py-6 text-sm text-stone-400 flex justify-between items-center">
        <span>John Nardone</span>
        <div class="flex gap-4">
          <a href="https://github.com/jnard0ne" class="hover:text-stone-700 transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/jnardonejr/" class="hover:text-stone-700 transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
